# =============================================================
# Validly Autonomous Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The easiest way to set this up is to run:
#   ./setup.sh
# =============================================================

# --- Local AI model (pulled automatically by Ollama on first start) ---
# Smaller/faster alternatives: qwen2.5:7b, llama3.2:3b, mistral:7b
OLLAMA_MODEL=qwen2.5:14b

# --- Telegram Bot (recommended — easiest notification method) ---
# Run ./setup.sh for guided setup, or:
#   1. Message @BotFather on Telegram → /newbot → copy the token below
#   2. Send any message to your new bot
#   3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord webhook (optional alternative to Telegram) ---
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# --- Digest schedule ---
# Hour (UTC, 0-23) when the daily best-idea digest is sent
DIGEST_HOUR=8

# --- Crawler behaviour ---
# Seconds to wait between crawl cycles (minimum recommended: 60)
CRAWL_DELAY_SECONDS=120
# Days before a subreddit is considered stale and re-crawled
SUBREDDIT_STALENESS_DAYS=3
# Maximum number of ideas to keep in the database
MAX_IDEAS_IN_DB=500

# --- Advanced overrides (defaults work fine with Docker Compose) ---
# POSTGRES_URL=postgresql://agent:agent@postgres:5432/validly
# OLLAMA_URL=http://ollama:11434
# SEARXNG_URL=http://searxng:8080
